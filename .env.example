# Host ports exposed to the internet (open these in firewall/security group).
FRONTEND_PORT=8086
BACKEND_PORT=3001

# Production mode defaults.
USE_MOCK_DATA=false
JWT_SECRET=replace-with-strong-secret
# Optional comma-separated allowlist, for example:
# CORS_ORIGINS=https://cafeteria.example.org,https://admin.example.org
CORS_ORIGINS=

# Postgres mode (used when USE_MOCK_DATA=false)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mtc_cafeteria
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/mtc_cafeteria
