# Host ports exposed to the internet (open these in firewall/security group).
FRONTEND_PORT=8086
BACKEND_PORT=3001
POSTGRES_PORT=5434

# Start with mock data for prototype mode.
USE_MOCK_DATA=true
JWT_SECRET=replace-with-strong-secret

# Postgres mode (used when USE_MOCK_DATA=false)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mtc_cafeteria
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/mtc_cafeteria
